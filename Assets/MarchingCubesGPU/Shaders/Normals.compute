
#pragma kernel CSMain

Texture3D<float> _Noise;

RWTexture3D<float3> _Result;

int _Width, _Height;

[numthreads(8,8,8)]
void CSMain (uint3 id : SV_DispatchThreadID)
{
	float v = _Noise[id];
	float dx = v - _Noise[id + int3(1, 0, 0)];
	float dy = v -_Noise[id + int3(0, 1, 0)];
	float dz = v -_Noise[id + int3(0, 0, 1)];
	_Result[id] = normalize(float3(dx,dy,dz));

}
